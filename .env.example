# ─── Database (Cloud SQL Postgres in prod; local Postgres or docker-compose in dev) ───
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/proposal_agent?schema=public"

# ─── Auth.js (NextAuth v5) ───
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Platform break-glass admins — comma-separated emails granted SUPER_ADMIN on first login,
# regardless of organization domain. Safety net for login outside whitelisted domains.
SUPERADMIN_EMAILS="you@example.com"

# ─── Vertex AI (Gemini) ───
GOOGLE_CLOUD_PROJECT="elivision-ai-1"
VERTEX_LOCATION="global"
GEMINI_MODEL="gemini-3.5-flash"
# Local dev only: path to a service-account key JSON.
# On Cloud Run leave empty — the runtime service account (ADC) is used automatically.
GOOGLE_APPLICATION_CREDENTIALS=""
# Set to "true" to use a deterministic mock LLM (no Vertex calls) — used by unit tests.
LLM_MOCK="false"

# ─── File storage ───
# If GCS_BUCKET is set, uploads go to Google Cloud Storage; otherwise a local .uploads/ dir.
GCS_BUCKET=""

# ─── Langfuse (optional — tracing is disabled if keys are unset) ───
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST="https://cloud.langfuse.com"

# ─── MCP stdio server (optional — only for `npm run mcp:stdio`) ───
# An organization API key created in the admin panel (Admin → API keys).
MCP_API_KEY=""

# ─── App ───
NODE_ENV="development"
